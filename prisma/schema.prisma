generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAINER
  CLIENT
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  PENDING_APPROVAL
}

enum ActorType {
  TRAINER
  CLIENT
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  REQUEST_REJECTED
  REQUEST_APPROVED
  SLOT_AVAILABLE
  CLIENT_CANCELLED
  CLIENT_RESCHEDULED
  CLIENT_BOOKED
  TRAINER_CANCELLED
  TRAINER_RESCHEDULED
  LATE_RESCHEDULE_REQUEST
}

enum WorkoutType {
  HERCULES
  REFORMER
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  role               UserRole
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clientProfile     ClientProfile?
  notifications     Notification[]
  clients           ClientProfile[] @relation("TrainerClients")
  workoutTemplates  WorkoutTemplate[]
}

model ClientProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  trainerId   String
  notes       String?
  injuries    String?
  goals       String?
  dateOfBirth DateTime?

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainer User @relation("TrainerClients", fields: [trainerId], references: [id], onDelete: Cascade)

  clientPackages   ClientPackage[]
  trainingRequests TrainingRequest[]
  bookings         Booking[]
}

model Package {
  id           String  @id @default(uuid())
  name         String  @unique
  sessionCount Int
  active       Boolean @default(true)

  clientPackages ClientPackage[]
}

model ClientPackage {
  id                String        @id @default(uuid())
  clientId          String
  packageId         String
  remainingSessions Int
  paymentStatus     PaymentStatus
  assignedAt        DateTime      @default(now())
  active            Boolean       @default(true)

  client  ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  package Package       @relation(fields: [packageId], references: [id])

  bookings Booking[]
}

model TrainingRequest {
  id               String        @id @default(uuid())
  clientId         String
  requestedStartAt DateTime
  requestedEndAt   DateTime
  note             String?
  status           RequestStatus @default(PENDING)
  reviewedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  booking Booking?
}

model WorkoutTemplate {
  id        String      @id @default(uuid())
  trainerId String
  name      String
  type      WorkoutType
  content   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  bookings Booking[]
}

model Booking {
  id                 String        @id @default(uuid())
  clientId           String
  trainingRequestId  String?       @unique
  clientPackageId    String
  workoutTemplateId  String?
  startAt            DateTime
  endAt              DateTime
  requestedStartAt   DateTime?
  requestedEndAt     DateTime?
  status             BookingStatus @default(CONFIRMED)
  createdBy          ActorType
  cancelledBy        ActorType?
  cancelledAt        DateTime?
  cancellationReason String?
  completedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  client           ClientProfile     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainingRequest  TrainingRequest?  @relation(fields: [trainingRequestId], references: [id])
  clientPackage    ClientPackage     @relation(fields: [clientPackageId], references: [id])
  workoutTemplate  WorkoutTemplate?  @relation(fields: [workoutTemplateId], references: [id])

  workoutLog WorkoutLog?
  notifications Notification[]
}

model WorkoutLog {
  id        String   @id @default(uuid())
  bookingId String   @unique
  notes     String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  exercises ExerciseLog[]
}

model ExerciseLog {
  id           String  @id @default(uuid())
  workoutLogId String
  name         String
  sets         Int?
  reps         Int?
  weight       Float?
  notes        String?

  workoutLog WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  bookingId String?
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  booking Booking? @relation(fields: [bookingId], references: [id])
}